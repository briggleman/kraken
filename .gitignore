# Binaries
/bin/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test / coverage
*.test
*.out
coverage.*

# Go workspace sum
go.work.sum

# Environment / secrets
.env
.env.*
!.env.example
*.pem
*.key
!**/testdata/**/*.key
certs/
# Agent SSH/SFTP host key (ed25519, generated on first run; extensionless)
sftp_host_key
sftp_host_key.pub

# Node / web
web/node_modules/
web/dist/
web/.vite/
npm-debug.log*
# Vite output lands in the Go embed target — see web/vite.config.ts.
# The dist/ directory is committed with a stub index.html + a .gitignore
# so `//go:embed all:dist` compiles in a fresh checkout, but the real
# build artifacts (assets/, hashed js/css) are ignored via that inner file.

# Editor / OS
.idea/
.vscode/
.DS_Store
Thumbs.db

# Local / runtime data (bind-mounted server data, backups, dev logs).
# Not root-anchored: integration tests can create these under internal/agent too.
/data/
server-data/
backups/
agent-backups/
*.sqlite
*.log

# Local agent / editor tooling
.claude/
