# Kraken deploy environment — copy to deploy/.env and edit.
#
# The full-stack compose file (docker-compose.full.yml) picks these up:
#   docker compose --env-file deploy/.env -f deploy/docker-compose.full.yml up -d
#
# For the bare-metal path (systemd), install.sh writes the same variables
# to /etc/kraken/panel.env and /etc/kraken/agent.env.

# ---- required ----------------------------------------------------------

# Master key used to seal all at-rest secrets (Steam creds, CA key,
# SFTP keys, integration tokens). Generate once and keep it — losing it
# means every stored secret becomes unrecoverable.
#
#   openssl rand -base64 32
KRAKEN_SECRETS_KEY=

# ---- recommended -------------------------------------------------------

# First admin. On a fresh database a bootstrap user is created with these
# credentials; on subsequent starts the value is ignored (the login
# persists in Postgres). Leave the password blank to let the Panel
# generate a strong random one and log it once.
KRAKEN_BOOTSTRAP_ADMIN_USER=admin
KRAKEN_BOOTSTRAP_ADMIN_PASSWORD=

# Where the Agent stores game-server data on the host. Bind-mounted into
# every game container as /data (Linux) / C:\data (Windows).
KRAKEN_DATA_DIR=/var/lib/kraken/server-data

# Where the Agent writes local backups before optional off-site replication.
KRAKEN_BACKUP_DIR=/var/lib/kraken/agent-backups

# ---- optional ----------------------------------------------------------

# Panel HTTP port. Default 8080.
# KRAKEN_HTTP_PORT=8080

# SFTP listen address. Expose to trusted networks only.
# KRAKEN_SFTP_ADDR=:2022

# Comma-separated list of external origins allowed to hit the Panel API
# and open WebSockets. Same-origin is always allowed; localhost is always
# allowed in dev. Set this for reverse-proxied deployments.
# KRAKEN_ALLOWED_ORIGINS=https://kraken.example.com

# Pin to a specific Panel/Agent image (default: :latest).
# KRAKEN_PANEL_IMAGE=ghcr.io/briggleman/kraken-panel:v0.5.0
# KRAKEN_AGENT_IMAGE=ghcr.io/briggleman/kraken-agent:v0.5.0
