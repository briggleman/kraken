# /etc/systemd/system/kraken-agent.service
#
# Kraken Agent — per-host daemon; launches game-server containers via the
# local Docker daemon. Runs as the `kraken` system user (member of the
# `docker` group so it can talk to /var/run/docker.sock). Binds :9090 for
# Panel gRPC and :2022 for SFTP.

[Unit]
Description=Kraken Agent (node daemon)
Documentation=https://github.com/briggleman/kraken
After=network-online.target docker.service
Wants=network-online.target
Requires=docker.service

[Service]
Type=simple
User=kraken
Group=kraken
SupplementaryGroups=docker
EnvironmentFile=-/etc/kraken/agent.env
Environment=KRAKEN_STATE_DIR=/var/lib/kraken
ExecStart=/usr/local/bin/kraken-agent
Restart=on-failure
RestartSec=5s
# --- hardening ------------------------------------------------------------
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
# Needs write for state, host key, server data, and backups. The default
# server-data + backup dirs are under /var/lib/kraken but operators can
# point elsewhere via KRAKEN_DATA_DIR / KRAKEN_BACKUP_DIR — add those
# via a systemd drop-in (systemctl edit kraken-agent) if you move them.
ReadWritePaths=/var/lib/kraken /etc/kraken
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
RestrictSUIDSGID=true
LockPersonality=true

[Install]
WantedBy=multi-user.target
